# ============================================================================
# Peddler Environment Configuration
# ============================================================================
# Скопируйте этот файл в .env и заполните реальными значениями

# Application
APP_NAME=Peddler
APP_VERSION=1.0.0
DEBUG=false

# Server
BACKEND_PORT=8000
WORKERS=4

# Database
DB_USER=peddler
DB_PASS=CHANGE_ME_strong_password_123
DB_NAME=peddler
DB_PORT=5432
DB_ECHO=false

# Redis
REDIS_PASSWORD=CHANGE_ME_redis_password_456
REDIS_PORT=6379

# JWT
SECRET_KEY=CHANGE_ME_random_secret_key_at_least_32_chars
ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=10080

# CORS
ALLOWED_ORIGINS=http://localhost:3000,https://yourdomain.com
CORS_CREDENTIALS=true

# Logging
LOG_LEVEL=INFO
