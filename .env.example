DOMAIN=hushme.fun

# Database
DB_HOST=
DB_PORT=
DB_USER=
DB_PASS=
DB_NAME=

# Redis & Celery
USE_REDIS_PUBSUB=true
REDIS_PASSWORD=

# В Docker-compose redis доступен по имени хоста `redis`
REDIS_URL=redis://:${REDIS_PASSWORD}@redis:6379/0
CELERY_BROKER_URL=redis://:${REDIS_PASSWORD}@redis:6379/1
CELERY_RESULT_BACKEND=redis://:${REDIS_PASSWORD}@redis:6379/2
CELERY_TASK_TRACK_STARTED=true
CELERY_TASK_TIME_LIMIT=300

# Backend & Security
SECRET_KEY=
ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=15
DEBUG=false
BACKEND_PORT=8000

# CORS
ALLOWED_ORIGINS=https://hushme.fun,https://www.hushme.fun
CORS_CREDENTIALS=true

# Frontend
VITE_BASE_URL=https://hushme.fun
VITE_API_URL=https://hushme.fun/api/v1
VITE_WS_PROTOCOL=wss
VITE_WS_HOST=hushme.fun
VITE_TUS_URL=https://hushme.fun/files/
